#   title = "MCD Analysis Report"
# )
}
# main()
# save workbook
# make sure run_mcd.R is sourced first!
xlsx_file <- save_analysis_outputs(
final_input = final_input,
res = res,
out_dir = out_dir,
alpha = 0.05,
top_n = 25,
include_group_sheets=FALSE
)
build_outlier_summary_table <- function(res, alpha = 0.05, top_n = 25) {
out <- lapply(names(res$mcd_results_by_group), function(g) {
tbl <- res$mcd_results_by_group[[g]]
cm <- res$contrast_matrices[[g]]
p_col <- get_primary_p_col(tbl)
eff <- get_gene_effect_summary(cm)
ranked_contrasts <- get_ranked_contrasts(cm)
eff$ranked_contrasts <- ranked_contrasts[match(eff$gene, names(ranked_contrasts))]
x <- merge(tbl, eff, by = "gene", all.x = TRUE, sort = FALSE)
x$p_value_used <- p_col
x$p_value <- x[[p_col]]
x$outlier_flag <- x$p_value < alpha
x$top_gene_flag <- x$outlier_flag | (x$rank_mahalanobis <= top_n)
keep_cols <- c(
intersect(c("group_id", "timepoint", "cell_line", "treatment"), colnames(x)),
"gene",
"outlier_flag",
# "top_gene_flag",
# "p_value_used",
"p_value",
"mahalanobis",
"rank_mahalanobis",
"mean_effect",
"sd_effect",
"max_abs_contrast",
"max_abs_contrast_name",
"ranked_contrasts"
# "n_contrasts"
)
x[, keep_cols, drop=FALSE]
})
out.df = do.call(rbind, out)
cm.all = do.call(cbind, res$contrast_matrices)
cm.all = as.data.frame(cm.all)
cm.all$gene = rownames(cm.all)
merge(out.df, cm.all, by = 'gene')
}
get_gene_effect_summary <- function(contrast_matrix) {
mean_effect <- rowMeans(contrast_matrix, na.rm = TRUE)
sd_effect <- apply(contrast_matrix, 1, sd, na.rm = TRUE)
max_idx <- max.col(abs(contrast_matrix), ties.method = "first")
max_abs_contrast <- contrast_matrix[cbind(seq_len(nrow(contrast_matrix)), max_idx)]
max_abs_contrast_name <- colnames(contrast_matrix)[max_idx]
data.frame(
gene = rownames(contrast_matrix),
mean_effect = mean_effect,
sd_effect = sd_effect,
max_abs_contrast = max_abs_contrast,
max_abs_contrast_name = max_abs_contrast_name,
stringsAsFactors = FALSE
)
}
