get_script_dir <- function() {
cmdArgs <- commandArgs(trailingOnly = FALSE)
fileArgName <- "--file="
scriptPath <- sub(fileArgName, "", cmdArgs[grep(fileArgName, cmdArgs)])
if (length(scriptPath) > 0) {
return(dirname(normalizePath(scriptPath)))
}
return(getwd())
}
